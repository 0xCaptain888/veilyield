# ---------------------------------------------------------------------------
# VeilYield environment variables
# Copy this file to ".env" and fill in your own values. NEVER commit ".env".
# ---------------------------------------------------------------------------

# 12-word mnemonic that funds deployments and is used as the test wallet on Sepolia.
# For Sepolia testnet only — use a throwaway mnemonic, never one holding real funds.
# You can generate one at https://iancoleman.io/bip39/ (offline) or from MetaMask.
MNEMONIC="test test test test test test test test test test test junk"

# Sepolia JSON-RPC endpoint. A free public one is pre-filled in hardhat.config.ts,
# but a dedicated Alchemy/Infura key is more reliable for FHEVM (encrypted) txs.
# Example (Alchemy): https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# Optional: Etherscan API key for `npx hardhat verify`.
ETHERSCAN_API_KEY=""

# ---------------------------------------------------------------------------
# Frontend (Vite) variables live in frontend/.env — see frontend/.env.example
# ---------------------------------------------------------------------------
